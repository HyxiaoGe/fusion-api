DATABASE_URL=postgresql://fusion:fusion123!!@localhost:5432/fusion?client_encoding=utf8
SERVER_HOST=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
AUTH_SERVICE_BASE_URL=http://localhost:8100
AUTH_SERVICE_JWKS_URL=http://localhost:8100/.well-known/jwks.json
AUTH_SERVICE_CLIENT_ID=fusion-client
# 服务端内网直连地址（可选）。设置后 JWKS/userinfo 走内网，绕开公网域名经 Cloudflare 的回环延迟。
# issuer 仍用上面的 AUTH_SERVICE_BASE_URL 校验。本地开发留空即可。
# dev Docker 网络中使用 http://auth-service:8100，不要写宿主机 IP:8100（auth-service 未发布该端口）。
AUTH_SERVICE_INTERNAL_BASE_URL=
DEFAULT_MODEL=qwen
SEARCH_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
GOOGLE_API_BASE=
HUNYUAN_APP_ID=
HUNYUAN_SECRET_ID=
HUNYUAN_SECRET_KEY=
OPENAI_BASE_URL=
OPENAI_API_KEY=
VOLCENGINE_API_KEY=
VOLCENGINE_API_BASE=
QIANFAN_AK=
QIANFAN_SK=
XAI_API_KEY=
XAI_API_BASE=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis（容器内通过 middleware_default 网络连接已有的 middleware-redis）
REDIS_URL=redis://middleware-redis:6379/0

# 必须大于 reader-service 的 18 秒总截止时间，给结构化错误返回和网络传输留出余量。
READER_SERVICE_TIMEOUT=20

# Moonshot (Kimi) — 动态示例问题
MOONSHOT_API_KEY=

# BYOK：user_credentials.api_key 用 Fernet 对称加密存储。
# 生成命令：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# **重要：丢失此 key 会导致所有用户已存的 api_key 无法解密**
CREDENTIAL_ENCRYPTION_KEY=

# 存储后端（"local"、"minio" 或 "oss"）
STORAGE_BACKEND=local
FILE_STORAGE_KEY_PREFIX=files/v1
FILE_UPLOAD_TIMEOUT_SECONDS=60
DIRECT_UPLOAD_STALE_SECONDS=1800
MINIO_ENDPOINT=192.168.1.10:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=fusion-files
MINIO_USE_SSL=false
MINIO_PRESIGN_EXPIRES=3600
OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=fusion-file
OSS_USE_SSL=true
